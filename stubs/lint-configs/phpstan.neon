includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 10
    tmpDir: /tmp/phpstan

    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - routes

    excludePaths:
        - database/migrations/*
        - database/factories/*
        - config/*.php
        - bootstrap/cache/*
        - storage/*
